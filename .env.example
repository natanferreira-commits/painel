# Copie este arquivo para .env.local e preencha com as chaves do seu projeto Supabase.
# (Project Settings > API, no painel do Supabase)

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Opcional. Um texto secreto qualquer. Se preencher, configure a URL do webhook
# no SendPulse como https://SEU-DOMINIO/api/sendpulse?secret=ESSE_VALOR
SENDPULSE_WEBHOOK_SECRET=

# Senha de acesso ao painel (login). Se vazio, o painel fica aberto.
# Em producao (Vercel), defina sempre.
PANEL_PASSWORD=

# Chave da API da Anthropic (console.anthropic.com), pra categorizacao do Modulo A.
ANTHROPIC_API_KEY=
